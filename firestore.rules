rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAiGuidesAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /plans/{planId} {
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    match /plans/{planId}/rows/{rowId} {
      allow read, write: if request.auth != null
        && get(/databases/$(database)/documents/plans/$(planId)).data.ownerId == request.auth.uid;
    }

    match /contacts/{contactId} {
      allow read, update, delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Read-only enum catalog for client dropdowns.
    match /EnumsCatalog/{enumId} {
      allow read, write: if true;
    }

    // Backward-compatible lowercase collection variant.
    match /enumsCatalog/{enumId} {
      allow read, write: if true;
    }

    // Read-only AI guides catalog for client content rendering.
    match /AiGuides/{guideId} {
      allow read: if true;
      allow write: if isAiGuidesAdmin();
    }

    // Backward-compatible lowercase collection variant.
    match /aiGuides/{guideId} {
      allow read: if true;
      allow write: if isAiGuidesAdmin();
    }

    // Editor draft collection for AiGuides content.
    match /AiGuides_draft/{guideId} {
      allow read, write: if isAiGuidesAdmin();
    }

    // Publish audit metadata for AiGuides releases.
    match /AiGuides_publish_meta/{publishId} {
      allow read, write: if isAiGuidesAdmin();
    }
  }
}