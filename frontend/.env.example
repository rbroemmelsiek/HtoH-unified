# Copy to .env.local and fill in values. Restart `npm run dev` after changes.
# Firebase project: HtOH-3-0 (https://console.firebase.google.com/project/htoh-3-0)

# Firebase Web SDK – from Firebase Console > Project settings > Your apps > HomeToHome
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=htoh-3-0.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=htoh-3-0
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=htoh-3-0.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=769485574848
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Plan gateway: firebase | local
NEXT_PUBLIC_PLAN_DATASOURCE=local
NEXT_PUBLIC_PLAN_COLLECTION=plans
NEXT_PUBLIC_PLAN_ID=plan_0

# Cloud Functions
NEXT_PUBLIC_PLAN_AI_FUNCTION_URL=https://us-central1-htoh-3-0.cloudfunctions.net/planAiAssist
NEXT_PUBLIC_GEMINI_PROXY_URL=https://us-central1-htoh-3-0.cloudfunctions.net/geminiProxy
NEXT_PUBLIC_PLAN_APP_PORT=5174

# Local emulators
NEXT_PUBLIC_API_URL=http://127.0.0.1:5001/htoh-3-0/us-central1
NEXT_PUBLIC_BACKEND_API_URL=http://127.0.0.1:8085
